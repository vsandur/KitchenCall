{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kitchencall.local/schemas/action.schema.json",
  "title": "KitchenCall Action",
  "description": "Discriminated by intent. Mirrors apps/api/app/schemas/action.py.",
  "oneOf": [
    {
      "type": "object",
      "required": ["intent", "menu_item_id"],
      "properties": {
        "intent": { "const": "add_item" },
        "menu_item_id": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "size": { "type": ["string", "null"] },
        "qty": { "type": "integer", "minimum": 1 },
        "modifiers": { "type": "array", "items": { "type": "string" } },
        "special_instructions": { "type": ["string", "null"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent", "target_item_id"],
      "properties": {
        "intent": { "const": "modify_item" },
        "target_item_id": { "type": "string" },
        "changes": { "type": "object" },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent", "target_item_id"],
      "properties": {
        "intent": { "const": "remove_item" },
        "target_item_id": { "type": "string" },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent", "question"],
      "properties": {
        "intent": { "const": "ask_clarification" },
        "question": { "type": "string" },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "const": "answer_menu_question" },
        "topic": { "type": ["string", "null"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent", "order_type"],
      "properties": {
        "intent": { "const": "set_order_type" },
        "order_type": { "type": "string", "enum": ["pickup", "delivery"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "const": "set_customer_info" },
        "name": { "type": ["string", "null"] },
        "phone": { "type": ["string", "null"] },
        "address": { "type": ["string", "null"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "const": "confirm_order" },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "const": "cancel_order" },
        "reason": { "type": ["string", "null"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    },
    {
      "type": "object",
      "required": ["intent"],
      "properties": {
        "intent": { "const": "transfer_to_staff" },
        "reason": { "type": ["string", "null"] },
        "assistant_followup": { "type": ["string", "null"] }
      }
    }
  ]
}
