# Optional: override paths (defaults under apps/api/data/)
# KITCHENCALL_MENU_PATH=/absolute/path/to/menu.json
# KITCHENCALL_DATABASE_PATH=/absolute/path/to/kitchencall.db

# Comma-separated origins for dashboard dev server
# KITCHENCALL_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LiveKit tokens for POST /livekit/token (dashboard “Connect LiveKit mic”)
# KITCHENCALL_LIVEKIT_URL=wss://your-project.livekit.cloud
# KITCHENCALL_LIVEKIT_API_KEY=...
# KITCHENCALL_LIVEKIT_API_SECRET=...

# Optional: worker heartbeat file read by GET /agent/status
# KITCHENCALL_AGENT_HEARTBEAT_PATH=/tmp/kitchencall-agent-heartbeat.json
# KITCHENCALL_AGENT_HEARTBEAT_STALE_AFTER_SECONDS=20

# Optional: Twilio inbound bridge mode (say_only | stream | sip)
# KITCHENCALL_TWILIO_BRIDGE_MODE=stream
# Public WSS to this API, e.g. wss://api.example.com/telephony/twilio/media
# KITCHENCALL_TWILIO_MEDIA_STREAM_URL=wss://api.example.com/telephony/twilio/media
# KITCHENCALL_TWILIO_SIP_URI=sip:voice-agent@example.sip.twilio.com
# Media Streams → cart (install: pip install -r requirements-telephony.txt for faster_whisper)
# <Connect><Stream> must use inbound_track only (Twilio). TTS back to caller uses WS media out.
# KITCHENCALL_TWILIO_STREAM_TRACK is reserved if we add <Start> streams later.
# KITCHENCALL_TWILIO_STREAM_TTS_BACKEND=auto
# Optional TwiML Say before <Stream> (empty = built-in ordering script)
# KITCHENCALL_TWILIO_VOICE_GREETING=
# Cloud STT (recommended — local Whisper is too slow on free-tier CPUs):
# KITCHENCALL_TWILIO_STREAM_STT_BACKEND=deepgram   # Deepgram Nova-2 (fast, free tier: $200 credit)
# KITCHENCALL_TWILIO_STREAM_STT_BACKEND=openai     # OpenAI Whisper API
# KITCHENCALL_STT_API_KEY=your-api-key-here
#
# Local STT (needs strong CPU):
# KITCHENCALL_TWILIO_STREAM_STT_BACKEND=faster_whisper
# KITCHENCALL_TWILIO_WHISPER_MODEL=base
#
# Generic HTTP endpoint:
# KITCHENCALL_TWILIO_STREAM_STT_BACKEND=http
# KITCHENCALL_TWILIO_STT_HTTP_URL=http://127.0.0.1:8080/transcribe
# KITCHENCALL_TWILIO_UTTERANCE_SILENCE_MS=700
# KITCHENCALL_TWILIO_UTTERANCE_MAX_MS=25000
# KITCHENCALL_TWILIO_UTTERANCE_RMS_THRESHOLD=280

# Optional: local/OSS LLM extracts actions (OpenAI-compatible API, e.g. Ollama). Still validated by state engine.
# Default URL is localhost Ollama — no API key required on loopback. See docs/oss-stack.md.
# KITCHENCALL_LOGIC_EXTRACTOR=llm
# KITCHENCALL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# KITCHENCALL_LLM_MODEL=llama3.2:3b
# KITCHENCALL_LLM_API_KEY=
# KITCHENCALL_LLM_TIMEOUT_SECONDS=120
# PersonaPlex natural voice agent (dual-loop: voice + shadow cart pipeline)
# Requires PersonaPlex-MLX running on localhost:8998 (see apps/personaplex/)
# KITCHENCALL_PERSONAPLEX_ENABLED=true
# KITCHENCALL_PERSONAPLEX_WS_URL=ws://localhost:8998/api/chat
# KITCHENCALL_PERSONAPLEX_VOICE=NATF2
# Cap menu prompt length for WS URL safety (upgrade line limits). Default 3500.
# KITCHENCALL_PERSONAPLEX_PROMPT_MAX_CHARS=3500
# Send silence+marks until PersonaPlex outputs audio (set false while debugging outbound audio).
# KITCHENCALL_TWILIO_PP_SILENCE_KEEPALIVE=true
# Play a short test tone after Media Stream starts (ms). If you hear it, outbound WSS→Twilio works.
# KITCHENCALL_TWILIO_PP_DEBUG_TONE_MS=0
# On the PersonaPlex-MLX process only: default 0 (MLX on main thread). Set 1 to run warmup in a
# thread so the handshake byte is sent before step_system_prompts finishes (faster, may be unstable).
# PERSONAPLEX_WARM_IN_THREAD=0

KITCHENCALL_LOGIC_EXTRACTOR=llm
# optional if you switch models:
# KITCHENCALL_LLM_MODEL=llama3.2:3b